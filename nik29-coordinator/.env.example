# OpenAI API Key (obbligatoria)
OPENAI_API_KEY=sk-...

# Manus API Key (per tool ask_manus - opzionale)
MANUS_API_KEY=

# URL manifest per auto-update
MAESTRO_UPDATE_URL=https://raw.githubusercontent.com/nsgambelluri61-design/nik29-coordinator/main/manifest.json

# Configurazione workspace e memoria
WORKSPACE_DIR=/data/workspace
MEMORY_DIR=/data/memory
HOST_URL=http://localhost:4001

# ============================================================
# TELEGRAM BOT
# ============================================================

# Token del bot Telegram (ottenuto da @BotFather)
TELEGRAM_BOT_TOKEN=

# ID Telegram dell'utente autorizzato (il tuo ID numerico)
# Per trovarlo: scrivi a @userinfobot su Telegram
# Supporta più ID separati da virgola: 123456789,987654321
TELEGRAM_ALLOWED_USER_ID=
